block MaterialBlock.RimLight : StylizedLobe in ShadingDomain
{
    consumes Normal ViewDirection RimMask;
    produces HoNprLobeOutput.emission;
    requires include HoNpr.StylizedLobes;
    requires define HONPR_HAS_RIM_LIGHT;
    entry HoNprEvaluateRimLight;
    variantPolicy PresetStatic;
    debug Lobe.Rim;
}
