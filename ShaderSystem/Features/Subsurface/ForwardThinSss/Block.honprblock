block MaterialBlock.ForwardThinSss : Subsurface in ShadingDomain
{
    consumes HoUrpSurfaceData HoLightingContext ViewDirection ForwardThinSssMask;
    produces HoNprLobeOutput.transmission;
    requires include HoNpr.Subsurface;
    requires define HONPR_HAS_FORWARD_THIN_SSS;
    entry HoNprEvaluateForwardThinSss;
    variantPolicy PresetStatic;
    debug Lobe.SSS;
}
