block MaterialBlock.PbrSpecularAnisotropic : SpecularLobe in ShadingDomain
{
    consumes HoUrpSurfaceData HoLightingContext Tangent AnisotropyMask;
    produces HoNprLobeOutput.specular;
    requires include HoNpr.PbrLobes;
    requires define HONPR_HAS_PBR_SPECULAR_ANISOTROPIC;
    entry HoNprEvaluatePbrSpecularAnisotropic;
    variantPolicy PresetStatic;
    debug Lobe.SpecularAnisotropic;
}
