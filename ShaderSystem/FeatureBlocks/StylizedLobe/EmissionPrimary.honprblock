block MaterialBlock.EmissionPrimary : StylizedLobe in ShadingDomain
{
    consumes EmissionColor EmissionMask;
    produces HoNprLobeOutput.emission;
    requires include HoNpr.StylizedLobes;
    requires define HONPR_HAS_EMISSION_PRIMARY;
    entry HoNprEvaluateEmissionPrimary;
    variantPolicy PresetStatic;
    debug Lobe.Emission;
}
