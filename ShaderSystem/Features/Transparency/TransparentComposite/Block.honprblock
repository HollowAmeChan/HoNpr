block MaterialBlock.TransparentComposite : Transparency in CompositeDomain
{
    consumes HoUrpTransparentOutputData Alpha Coverage;
    produces TransparentColor TransparentAlpha;
    requires include HoNpr.Transparency;
    requires define HONPR_HAS_TRANSPARENT_COMPOSITE;
    entry HoNprApplyTransparentComposite;
    variantPolicy PresetStatic;
    debug Transparency.Composite;
}
