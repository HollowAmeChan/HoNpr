block MaterialBlock.HairSpecularPrimary : SpecularLobe in ShadingDomain
{
    consumes Normal Tangent HairMask;
    produces HoNprLobeOutput.specular;
    requires include HoNpr.ToonLobes;
    requires define HONPR_HAS_HAIR_SPECULAR_PRIMARY;
    entry HoNprEvaluateHairSpecularPrimary;
    variantPolicy PresetStatic;
    debug Lobe.HairSpecular;
}
