block MaterialBlock.Backlight : StylizedLobe in ShadingDomain
{
    consumes LightDirection ViewDirection BacklightMask;
    produces HoNprLobeOutput.emission;
    requires include HoNpr.StylizedLobes;
    requires define HONPR_HAS_BACKLIGHT;
    entry HoNprEvaluateBacklight;
    variantPolicy PresetStatic;
    debug Lobe.Backlight;
}
