block MaterialBlock.RimShade : StylizedLobe in ShadingDomain
{
    consumes Normal ViewDirection RimMask;
    produces HoNprLobeOutput.diffuse;
    requires include HoNpr.StylizedLobes;
    requires define HONPR_HAS_RIM_SHADE;
    entry HoNprEvaluateRimShade;
    variantPolicy PresetStatic;
    debug Lobe.Rim;
}
