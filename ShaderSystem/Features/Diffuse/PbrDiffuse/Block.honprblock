block MaterialBlock.PbrDiffuse : DiffuseLobe in ShadingDomain
{
    consumes HoUrpSurfaceData HoLightingContext;
    produces HoNprLobeOutput.diffuse;
    requires include HoNpr.PbrLobes;
    requires define HONPR_HAS_PBR_DIFFUSE;
    entry HoNprEvaluatePbrDiffuse;
    variantPolicy PresetStatic;
    debug Lobe.Diffuse;
}
