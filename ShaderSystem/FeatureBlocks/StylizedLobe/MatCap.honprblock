block MaterialBlock.MatCap : StylizedLobe in ShadingDomain
{
    consumes MatCapTexture Normal ViewDirection;
    produces HoNprLobeOutput.specular;
    requires include HoNpr.StylizedLobes;
    requires define HONPR_HAS_MATCAP;
    entry HoNprEvaluateMatCap;
    variantPolicy PresetStatic;
    debug Lobe.MatCap;
}
