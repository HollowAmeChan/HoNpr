block MaterialBlock.MaterialSemanticProducer : SemanticProducer in MaterialDomain
{
    consumes MaterialClass SssProfile Thickness Curvature MaterialCustom0_3;
    produces Material.Class Material.SssProfile Material.Thickness Material.Curvature Material.Custom0-3;
    requires include HoNpr.SemanticSurface;
    requires define HONPR_HAS_MATERIAL_SEMANTICS;
    entry HoNprCreateMaterialSemanticProducer;
    variantPolicy PresetStatic;
    debug Semantic.Material;
}
